<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="192dp"
    android:height="192dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- The same Stylized 'M' but scaled/centered for splash -->
    <path
        android:pathData="M30,65 L40,65 L48,35 L60,75 L68,50 L78,50"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="30"
                android:startY="50"
                android:endX="78"
                android:endY="50"
                android:type="linear">
                <item android:offset="0" android:color="#00E5FF" />
                <item android:offset="1" android:color="#D500F9" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glowing effect -->
    <path
        android:pathData="M30,65 L40,65 L48,35 L60,75 L68,50 L78,50"
        android:strokeAlpha="0.3"
        android:strokeWidth="9"
        android:strokeLineCap="round"
        android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="30"
                android:startY="50"
                android:endX="78"
                android:endY="50"
                android:type="linear">
                <item android:offset="0" android:color="#00E5FF" />
                <item android:offset="1" android:color="#D500F9" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Particles -->
    <path
        android:fillColor="#00E5FF"
        android:pathData="M82,45a2,2 0,1 1,4 0a2,2 0,1 1,-4 0" />
    <path
        android:fillColor="#D500F9"
        android:pathData="M22,70a1.5,1.5 0,1 1,3 0a1.5,1.5 0,1 1,-3 0" />

</vector>
